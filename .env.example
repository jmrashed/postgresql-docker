# Example environment file.
# NOTE: Do not commit real secrets.
# `./setup.sh` generates a real `.env` with secure random passwords.

# PostgreSQL Superuser (used for initialization only)
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=CHANGE_ME

# Database 1 (CRM)
DB1_NAME=crm_db
DB1_USER=crm_app
DB1_PASSWORD=CHANGE_ME

# Database 2 (Inventory)
DB2_NAME=inventory_db
DB2_USER=inventory_app
DB2_PASSWORD=CHANGE_ME

# Database 3 (HR)
DB3_NAME=hr_db
DB3_USER=hr_app
DB3_PASSWORD=CHANGE_ME

# pgAdmin4 Configuration
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME

# Timezone
TZ=UTC

