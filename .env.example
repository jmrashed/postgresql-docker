# ============================================================================
# PostgreSQL Docker Compose Environment Configuration
# ============================================================================
# This file serves as a template. Run ./setup.sh to generate .env with random passwords.
# DO NOT commit .env to version control - it contains sensitive credentials
# ============================================================================

# PostgreSQL Superuser (used for initialization only)
POSTGRES_SUPERUSER=postgres
# Leave empty to generate random password on setup
POSTGRES_SUPERUSER_PASSWORD=

# Database 1 Configuration
DB1_NAME=crm_db
DB1_USER=crm_app
DB1_PASSWORD=

# Database 2 Configuration
DB2_NAME=inventory_db
DB2_USER=inventory_app
DB2_PASSWORD=

# Database 3 Configuration
DB3_NAME=hr_db
DB3_USER=hr_app
DB3_PASSWORD=

# pgAdmin4 Configuration
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=

# ============================================================================
# Timezone Configuration
# ============================================================================
# PostgreSQL timezone (e.g., UTC, America/New_York, Europe/London)
TZ=UTC

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================
# 1. Change ALL default passwords before deploying to production
# 2. Use strong, randomly generated passwords (min 16 characters)
# 3. Never commit .env file to version control
# 4. Rotate passwords regularly
# 5. Use secrets management (e.g., Docker Secrets, Vault) in production
# 6. Restrict file permissions: chmod 600 .env
# 7. Change pgAdmin default credentials before exposing to network

